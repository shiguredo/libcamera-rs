{
    "name": "libcamera-rs",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "containerEnv": {
        "PKG_CONFIG_ALLOW_CROSS": "1",
        "PKG_CONFIG_SYSROOT_DIR": "${containerWorkspaceFolder}/target/shiguredo-sysroot/raspberry-pi-os_armv8/sysroot",
        "PKG_CONFIG_LIBDIR": "${containerWorkspaceFolder}/target/shiguredo-sysroot/raspberry-pi-os_armv8/sysroot/usr/lib/aarch64-linux-gnu/pkgconfig:${containerWorkspaceFolder}/target/shiguredo-sysroot/raspberry-pi-os_armv8/sysroot/usr/share/pkgconfig",
        "BINDGEN_EXTRA_CLANG_ARGS_aarch64_unknown_linux_gnu": "--target=aarch64-linux-gnu --sysroot=${containerWorkspaceFolder}/target/shiguredo-sysroot/raspberry-pi-os_armv8/sysroot"
    },
    "postCreateCommand": ".devcontainer/setup.sh",
    "customizations": {
        "vscode": {
            "extensions": [
                "rust-lang.rust-analyzer"
            ],
            "settings": {
                "rust-analyzer.cargo.target": "aarch64-unknown-linux-gnu"
            }
        }
    }
}
